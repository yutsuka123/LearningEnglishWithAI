# Copy this file to ".env" and fill in your values.
# The app starts and runs locally even without an API key —
# only the AI-powered features require it.

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Model used for教材生成・添削・対話 (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Natural TTS model for読み上げ (default: gpt-4o-mini-tts)
OPENAI_TTS_MODEL=gpt-4o-mini-tts

# Your nickname (how the AI addresses you). Personal info lives ONLY here
# in .env — never in git-tracked files. Leave blank to stay anonymous.
USER_NICKNAME=

# Server host / port
HOST=127.0.0.1
PORT=8000

# USD→JPY 為替レート（費用の円換算用）。週1回見直し推奨。
USD_JPY_RATE=155
USD_JPY_AS_OF=2026-06-14

# --- AI コスト暴走ガード（不意の高額課金を防止）-----------------------------
# 1日(ローカル日)の合計AI費用の上限(USD)。超過で全AI呼び出しを停止。0で無効。
AI_DAILY_COST_CAP_USD=1.0
# 1分あたりのAI呼び出し回数の上限（ループ等の暴走を遮断）。
AI_MAX_CALLS_PER_MIN=20
# chat の max_tokens 上限（過大指定をクランプ）。
AI_MAX_OUTPUT_TOKENS=1500

# --- 音声(MP3)の保存方式 -----------------------------------------------------
# file = data/audio に番号＋声で保存 / db = DBにBLOB / hybrid = 両方。
AUDIO_STORAGE=file

# Data directory (optional). Defaults to ./data next to the app.
# DATA_DIR=
