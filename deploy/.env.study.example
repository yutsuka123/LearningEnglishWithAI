# VPS の eigo-app 用 env。VPS 上で `.env.study` にコピーして値を入れる。
# ★リポジトリには実値を置かない（このファイルは example のみ）。

# OpenAI（本アプリ専用キー推奨。ailab とは別管理）
OPENAI_API_KEY=

# 既定モデル（本アプリの方針）
OPENAI_MODEL=gpt-5.4-mini

# --- マルチユーザー（公開時は必須）---
MULTIUSER=1
# セッション署名鍵：本番は固定の長いランダム値を必ず設定（再起動でログアウトを防ぐ）。
#   例: python -c "import secrets;print(secrets.token_hex(32))"
SESSION_SECRET=
# HTTPS配信なので Secure Cookie を強制
COOKIE_SECURE=1

# --- セキュリティ / レート ---
# 汎用IPレート制限（req/分）。公開時は 300 程度から。
RATE_LIMIT_PER_MIN=300

# --- AIコストガード（暴走・不正の金銭被害に上限）---
AI_DAILY_COST_CAP_USD=35.5
AI_MAX_CALLS_PER_MIN=20
AI_MAX_OUTPUT_TOKENS=1500

# 為替（円換算・残高控除に使用）
USD_JPY_RATE=155

# 音声保存方式（file 推奨：data/audio に保存）
AUDIO_STORAGE=file
